<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.RekamMedisController"
            stylesheets="@style.css">

    <top>
        <VBox spacing="10" styleClass="top-panel">

            <Label text="REKAM MEDIS"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>

            <Label text="Riwayat rekam medis pasien (baca saja)"
                   maxWidth="Infinity"
                   alignment="CENTER"
                   style="-fx-font-size:14; -fx-text-fill:#7f8c8d;"/>

            <HBox spacing="15" alignment="CENTER">

                <Button text="↻"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>

                <Button text="ℹ"
                        onAction="#handleDetail"
                        styleClass="btn-secondary"/>

                <ComboBox fx:id="cbPasien"
                          promptText="Filter pasien..."
                          onAction="#handleFilterPasien"
                          prefWidth="220"/>

                <TextField fx:id="txtCari"
                           promptText="Cari pasien / dokter / diagnosa..."
                           prefWidth="320"/>

                <Button text="🔍"
                        onAction="#handleCari"
                        styleClass="btn-cari"/>

                <Button text="❌"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="main-panel">

            <TableView fx:id="tableRekam"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colTanggal" text="Tanggal"/>
                    <TableColumn fx:id="colPasien" text="Pasien"/>
                    <TableColumn fx:id="colDokter" text="Dokter"/>
                    <TableColumn fx:id="colDiagnosa" text="Diagnosa"/>
                    <TableColumn fx:id="colRingkasan" text="Ringkasan"/>
                    <TableColumn fx:id="colPrediksi" text="Prediksi"/>
                    <TableColumn fx:id="colResiko" text="Risiko"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
