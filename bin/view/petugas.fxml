<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PetugasController"
            stylesheets="@style.css">

    <top>
        <VBox spacing="10" styleClass="top-panel">

            <Label text="DATA PETUGAS"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>

            <HBox spacing="15" alignment="CENTER">

                <Button text="➕"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>

                <Button text="E"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <Button text="🗑"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>

                <TextField fx:id="txtCari"
                           promptText="Cari petugas..."
                           prefWidth="180"/>

                <Button text="🔍"
                        onAction="#handleCari"
                        styleClass="btn-cari"/>

                <Button text="❌"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="main-panel">

            <TableView fx:id="tablePetugas"
           VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colId"
                                text="ID"
                                prefWidth="120"/>

                    <TableColumn fx:id="colNama"
                                text="Nama"
                                prefWidth="350"/>

                    <TableColumn fx:id="colUsername"
                                text="Username"
                                prefWidth="300"/>

                    <TableColumn fx:id="colRole"
                                text="Role"
                                prefWidth="250"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>