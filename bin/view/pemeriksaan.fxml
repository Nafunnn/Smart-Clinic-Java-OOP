<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PemeriksaanController"
            prefWidth="1400"
            prefHeight="850"
            stylesheets="@style.css"
            style="-fx-background-color:#f4f7fb;">

    <top>

        <VBox spacing="20"
              alignment="CENTER"
              style="-fx-padding:30;">

            <!-- TITLE -->

            <VBox alignment="CENTER">

                <Label text="PEMERIKSAAN PASIEN"
                       style="
                       -fx-font-size:42;
                       -fx-font-weight:bold;
                       -fx-text-fill:#13294b;
                       "/>

                <Label text="Pemeriksaan dan Rekam Medis Pasien"
                       style="
                       -fx-font-size:16;
                       -fx-text-fill:#7f8c8d;
                       "/>

            </VBox>

            <!-- MENU -->

            <HBox spacing="18"
                  alignment="CENTER">

                <!-- tambah -->

                <Button text="+"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>

                <!-- edit -->

                <Button text="✎"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <!-- hapus -->

                <Button text="🗑"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>

                <!-- refresh -->

                <Button text="↻"
                        onAction="#handleRefresh"
                        styleClass="btn-refresh"/>

                <!-- search -->

                <TextField fx:id="txtCari"
                           promptText="Cari pasien / dokter / diagnosa..."
                           onKeyReleased="#handleCari"
                           prefWidth="320"
                           style="
                           -fx-background-radius:25;
                           -fx-border-radius:25;
                           -fx-padding:10 18;
                           -fx-font-size:14;
                           "/>
                <Button fx:id="btnPrint"
                        text="🖨"
                        onAction="#handlePrint"
                        styleClass="btn-secondary"/>
                <!-- close -->

                <Button text="✕"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>

        </VBox>

    </top>

    <!-- TABLE -->

    <center>

        <VBox style="
              -fx-padding:20;
              ">

            <TableView fx:id="tablePemeriksaan"
                       VBox.vgrow="ALWAYS"
                       style="
                       -fx-background-radius:18;
                       -fx-border-radius:18;
                       -fx-background-color:white;
                       ">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="70"/>

                    <TableColumn fx:id="colTanggal"
                                 text="Tanggal"
                                 prefWidth="130"/>

                    <TableColumn fx:id="colPasien"
                                 text="Pasien"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colDokter"
                                 text="Dokter"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colKeluhan"
                                 text="Keluhan"
                                 prefWidth="220"/>

                    <TableColumn fx:id="colDiagnosa"
                                 text="Diagnosa"
                                 prefWidth="220"/>

                    <TableColumn fx:id="colTekanan"
                                 text="Tekanan"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colGula"
                                 text="Gula"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colPrediksi"
                                 text="Prediksi"
                                 prefWidth="170"/>

                    <TableColumn fx:id="colResiko"
                                 text="Resiko"
                                 prefWidth="140"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>