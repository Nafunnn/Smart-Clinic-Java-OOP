<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormPetugasController"
            stylesheets="@style.css">

    <top>
        <VBox alignment="CENTER" spacing="15" styleClass="top-panel">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="FORM DATA PETUGAS"
                   styleClass="title"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="25">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <GridPane alignment="CENTER" hgap="20" vgap="18">

                <Label text="Nama"/>
                <TextField fx:id="txtNama"
                           prefWidth="250"
                           GridPane.columnIndex="1"/>

                <Label text="Username"
                       GridPane.rowIndex="1"/>
                <TextField fx:id="txtUsername"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <Label text="Password"
                       GridPane.rowIndex="2"/>
                <PasswordField fx:id="txtPassword"
                               prefWidth="250"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>

                <Label text="Role"
                       GridPane.rowIndex="3"/>
                <ComboBox fx:id="cmbRole"
                          prefWidth="250"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="3"/>

            </GridPane>

            <HBox spacing="20" alignment="CENTER">
                <Button text="💾 Simpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save"
                        prefWidth="120"
                        prefHeight="40"/>

                <Button text="✖ Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel"
                        prefWidth="120"
                        prefHeight="40"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>