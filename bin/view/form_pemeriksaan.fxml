<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormPemeriksaanController"
            prefWidth="1000"
            prefHeight="820"
            stylesheets="@style.css"
            style="-fx-background-color:#eef2f7;">

    <!-- HEADER -->

    <top>

        <VBox alignment="CENTER"
              spacing="10"
              style="
              -fx-background-color:linear-gradient(to right,#2563eb,#1e40af);
              -fx-background-radius:0 0 40 40;
              -fx-padding:35;
              ">

            <Label text="FORM PEMERIKSAAN"
                   style="
                   -fx-font-size:42;
                   -fx-font-weight:bold;
                   -fx-text-fill:white;
                   "/>

            <Label text="Pemeriksaan dan Rekam Medis Pasien"
                   style="
                   -fx-font-size:16;
                   -fx-text-fill:white;
                   "/>

        </VBox>

    </top>

    <!-- CONTENT -->

    <center>

        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:transparent;">

            <VBox spacing="25"
                  alignment="TOP_CENTER"
                  style="-fx-padding:30;">

                <!-- CARD -->

                <VBox spacing="25"
                      maxWidth="850"
                      style="
                      -fx-background-color:white;
                      -fx-background-radius:25;
                      -fx-padding:35;
                      -fx-effect:dropshadow(gaussian,#dfe6e9,15,0,0,5);
                      ">

                    <!-- IDENTITAS -->

                    <Label text="IDENTITAS PEMERIKSAAN"
                           style="
                           -fx-font-size:20;
                           -fx-font-weight:bold;
                           -fx-text-fill:#1e293b;
                           "/>

                    <GridPane hgap="20"
                              vgap="20">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="75"/>
                        </columnConstraints>

                        <!-- pendaftaran -->

                        <Label text="Pendaftaran"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <ComboBox fx:id="cbPendaftaran"
                                  promptText="Pilih pasien..."
                                  prefHeight="45"
                                  prefWidth="500"
                                  GridPane.rowIndex="0"
                                  GridPane.columnIndex="1"/>

                    </GridPane>

                    <!-- PEMERIKSAAN -->

                    <Label text="DATA PEMERIKSAAN"
                           style="
                           -fx-font-size:20;
                           -fx-font-weight:bold;
                           -fx-text-fill:#1e293b;
                           "/>

                    <GridPane hgap="20"
                              vgap="20">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="75"/>
                        </columnConstraints>

                        <!-- tekanan -->

                        <Label text="Tekanan Darah"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtTekanan"
                                   promptText="Contoh: 120"
                                   prefHeight="45"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                        <!-- gula -->

                        <Label text="Gula Darah"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtGula"
                                   promptText="Contoh: 90"
                                   prefHeight="45"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                        <!-- suhu -->

                        <Label text="Suhu"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtSuhu"
                                   promptText="Contoh: 36"
                                   prefHeight="45"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        <!-- berat -->

                        <Label text="Berat Badan"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtBerat"
                                   promptText="Contoh: 55"
                                   prefHeight="45"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="1"/>

                        <!-- diagnosa -->

                        <Label text="Diagnosa"
                               GridPane.rowIndex="4"
                               GridPane.columnIndex="0"/>

                        <TextArea fx:id="txtDiagnosa"
                                  promptText="Masukkan diagnosa dokter..."
                                  prefRowCount="3"
                                  wrapText="true"
                                  GridPane.rowIndex="4"
                                  GridPane.columnIndex="1"/>

                        <!-- prediksi -->

                        <Label text="Prediksi"
                               GridPane.rowIndex="5"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtPrediksi"
                                   promptText="Hasil prediksi AI"
                                   prefHeight="45"
                                   GridPane.rowIndex="5"
                                   GridPane.columnIndex="1"/>

                        <!-- resiko -->

                        <Label text="Tingkat Resiko"
                               GridPane.rowIndex="6"
                               GridPane.columnIndex="0"/>

                        <ComboBox fx:id="cbResiko"
                                  prefHeight="45"
                                  GridPane.rowIndex="6"
                                  GridPane.columnIndex="1"/>

                        <!-- catatan -->

                        <Label text="Catatan"
                               GridPane.rowIndex="7"
                               GridPane.columnIndex="0"/>

                        <TextArea fx:id="txtCatatan"
                                  promptText="Catatan tambahan..."
                                  prefRowCount="4"
                                  wrapText="true"
                                  GridPane.rowIndex="7"
                                  GridPane.columnIndex="1"/>

                    </GridPane>

                    <!-- RESEP -->

 <!-- RESEP -->

<Label text="RESEP OBAT"
       style="
       -fx-font-size:20;
       -fx-font-weight:bold;
       -fx-text-fill:#1e293b;
       "/>

<GridPane hgap="20"
          vgap="20">

    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="75"/>
    </columnConstraints>

    <!-- obat -->

    <Label text="Obat"
           GridPane.rowIndex="0"
           GridPane.columnIndex="0"/>

    <ComboBox fx:id="cbObat"
              prefHeight="45"
              GridPane.rowIndex="0"
              GridPane.columnIndex="1"/>

    <!-- jumlah -->

    <Label text="Jumlah"
           GridPane.rowIndex="1"
           GridPane.columnIndex="0"/>

    <TextField fx:id="txtJumlah"
               prefHeight="45"
               GridPane.rowIndex="1"
               GridPane.columnIndex="1"/>

    <!-- dosis -->

    <Label text="Dosis"
           GridPane.rowIndex="2"
           GridPane.columnIndex="0"/>

    <TextField fx:id="txtDosis"
               prefHeight="45"
               promptText="3x1 sehari"
               GridPane.rowIndex="2"
               GridPane.columnIndex="1"/>

    <!-- keterangan -->

    <Label text="Keterangan"
           GridPane.rowIndex="3"
           GridPane.columnIndex="0"/>

    <TextArea fx:id="txtKeterangan"
              prefRowCount="3"
              wrapText="true"
              GridPane.rowIndex="3"
              GridPane.columnIndex="1"/>

</GridPane>

<!-- tabel resep -->

<TableView fx:id="tableResep"
           prefHeight="200">

    <columns>

        <TableColumn fx:id="colObat"
                     text="Obat"
                     prefWidth="220"/>

        <TableColumn fx:id="colJumlah"
                     text="Jumlah"
                     prefWidth="100"/>

        <TableColumn fx:id="colDosis"
                     text="Dosis"
                     prefWidth="180"/>

        <TableColumn fx:id="colKeterangan"
                     text="Keterangan"
                     prefWidth="300"/>

    </columns>

</TableView>
                     <!-- tombol tambah obat -->

                     <HBox alignment="CENTER_RIGHT"
                     style="-fx-padding:10 0 10 0;">

                     <Button text="+ Tambah Obat"
                            onAction="#handleTambahObat"
                            styleClass="btn-primary"/>
                     <Button fx:id="btnHapusObat"
                            text="- Hapus Obat"
                            onAction="#handleHapusObat"
                            styleClass="btn-danger"/>
                     </HBox>

                    <!-- BUTTON -->

                    <HBox spacing="20"
                          alignment="CENTER">

                        <Button text="💾 Simpan"
                                onAction="#handleSimpan"
                                styleClass="btn-success"/>

                        <Button text="✖ Batal"
                                onAction="#handleBatal"
                                styleClass="btn-secondary"/>

                    </HBox>

                </VBox>

            </VBox>

        </ScrollPane>

    </center>

</BorderPane>