<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PendaftaranController"
            stylesheets="@style.css">

    <top>

        <VBox spacing="10"
              styleClass="top-panel">

            <Label text="PENDAFTARAN PERIKSA"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="➕"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>

                <Button text="✏"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <Button text="🗑"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>
                <!-- TEXTFIELD CARI -->
                <TextField fx:id="txtCari"
                        promptText="Cari pasien / dokter / keluhan..."
                        prefWidth="250"
                        onKeyReleased="#handleCari"/>                        

                <Button text="🔄"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>

                <Button text="❌"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <VBox spacing="15"
              styleClass="main-panel">

            <TableView fx:id="tablePendaftaran"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colTanggal"
                                 text="Tanggal"/>

                    <TableColumn fx:id="colPasien"
                                 text="Pasien"/>

                    <TableColumn fx:id="colDokter"
                                 text="Dokter"/>

                    <TableColumn fx:id="colKeluhan"
                                 text="Keluhan"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>