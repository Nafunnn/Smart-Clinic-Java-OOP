<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PetugasController"
            stylesheets="@style.css">

    <top>
        <VBox spacing="10" styleClass="top-panel">

            <Label text="SMART CLINIC"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>

            <Label text="MANAJEMEN PENGGUNA"
                   maxWidth="Infinity"
                   alignment="CENTER"
                   style="-fx-font-size:14; -fx-text-fill:#7f8c8d;"/>

            <HBox spacing="15" alignment="CENTER">

                <Button text="➕"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>

                <Button text="✏"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>

                <Button text="🗑"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>

                <Button text="🔄"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>

                <TextField fx:id="txtCari"
                           promptText="Cari pengguna..."
                           prefWidth="180"/>

                <Button text="🔍"
                        onAction="#handleCari"
                        styleClass="btn-cari"/>

                <Button text="❌"
                        onAction="#handleClose"
                        styleClass="btn-close"/>

            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" styleClass="main-panel">

            <TableView fx:id="tablePetugas"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colNama"
                                 text="Nama"/>

                    <TableColumn fx:id="colUsername"
                                 text="Username"/>

                    <TableColumn fx:id="colRole"
                                 text="Role"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
